{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@market-qr/database$": "<rootDir>/../packages/database/src",
    "^@market-qr/types$": "<rootDir>/../packages/types/src",
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
